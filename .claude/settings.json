{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/build_site.py)",
      "Bash(python3 scripts/brief.py)",
      "mcp__Claude_Browser__navigate",
      "mcp__Claude_Browser__read_page",
      "mcp__Claude_Browser__read_console_messages",
      "mcp__Claude_Browser__resize_window",
      "mcp__Claude_Browser__preview_list"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/brief.py 2>/dev/null || true",
            "timeout": 20,
            "statusMessage": "Reading project state"
          }
        ]
      }
    ]
  }
}
